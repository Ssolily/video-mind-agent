# VideoMind Agent Configuration
# Copy to .env and adjust values for your environment.
# cp .env.example .env

# --- Paths ---
# Root directory for all runtime data (videos, frames, reports, audio, clips)
VIDEOMIND_DATA_DIR=./data

# Directory for model files (YOLO, SAM2 checkpoints)
VIDEOMIND_MODEL_DIR=./models

# YOLO model path (filename or absolute/relative path)
VIDEOMIND_YOLO_MODEL_PATH=yolo11n.pt

# --- Upload Limits ---
# Maximum upload file size in megabytes
VIDEOMIND_MAX_UPLOAD_MB=500

# Maximum video duration in seconds (0 = no limit)
VIDEOMIND_MAX_VIDEO_DURATION_SEC=3600

# Maximum video resolution in pixels (0 = no limit)
VIDEOMIND_MAX_VIDEO_WIDTH=0
VIDEOMIND_MAX_VIDEO_HEIGHT=0

# Maximum video FPS (0 = no limit)
VIDEOMIND_MAX_VIDEO_FPS=0

# --- Concurrency ---
# Maximum number of concurrent background analysis tasks (default: 4)
VIDEOMIND_MAX_CONCURRENT_TASKS=4

# --- Server ---
VIDEOMIND_HOST=0.0.0.0
VIDEOMIND_PORT=8000
VIDEOMIND_DEBUG=false

# --- Database ---
# SQLite database URL (default: <DATA_DIR>/videomind.db)
# VIDEOMIND_DATABASE_URL=sqlite:///./data/videomind.db

# --- LLM (DeepSeek) ---
# API key for LLM-based planning. Leave empty to use rule-based planner.
DEEPSEEK_API_KEY=

# Model name (default: deepseek-v4-flash)
# DEEPSEEK_MODEL=deepseek-v4-flash

# API endpoint
# DEEPSEEK_CHAT_URL=https://api.deepseek.com/chat/completions

# --- Device (GPU / CPU) ---
# Global device selection: auto | cuda | cpu  (auto = CUDA if available, else CPU)
# VIDEOMIND_DEVICE=auto

# Per-model overrides (defaults to VIDEOMIND_DEVICE)
# VIDEOMIND_YOLO_DEVICE=
# VIDEOMIND_WHISPER_DEVICE=
# VIDEOMIND_WHISPER_COMPUTE_TYPE=int8_float16
# VIDEOMIND_SAM2_DEVICE=

# --- Highlight Scoring Weights ---
# Content weights (must sum to 1.0, validated at startup)
# VIDEOMIND_HIGHLIGHT_W_OBJECT=0.25
# VIDEOMIND_HIGHLIGHT_W_MOTION=0.20
# VIDEOMIND_HIGHLIGHT_W_SPEECH=0.20
# VIDEOMIND_HIGHLIGHT_W_SCENE=0.15
# VIDEOMIND_HIGHLIGHT_W_QUALITY=0.20

# Diversity penalty lambda (higher = more diverse selection)
# VIDEOMIND_HIGHLIGHT_DIVERSITY_LAMBDA=0.15

# Minimum score for a highlight to be included
# VIDEOMIND_HIGHLIGHT_MIN_SCORE=0.0

# Minimum and maximum candidate duration in seconds
# VIDEOMIND_HIGHLIGHT_MIN_DURATION=3.0
# VIDEOMIND_HIGHLIGHT_MAX_DURATION=45.0

# Storage Limits
VIDEOMIND_MAX_UPLOAD_MB=1024
VIDEOMIND_MAX_VIDEO_DURATION_SEC=7200
VIDEOMIND_MIN_FREE_DISK_GB=5
VIDEOMIND_MAX_TASK_STORAGE_MB=2048
# Monitor
VIDEOMIND_MONITOR_INTERVAL_SEC=30