# VideoMind Docker Environment Configuration
# Copy to .env.docker and adjust values for your environment.
#
# cp .env.docker.example .env.docker
#
# Default: CPU + rule planner (no GPU, no API key required).

# ── Server ───────────────────────────────────────────────────────────────
VIDEOMIND_HOST=0.0.0.0
VIDEOMIND_PORT=8000
VIDEOMIND_DEBUG=false

# ── Paths ────────────────────────────────────────────────────────────────
# (mounted as volumes, change only if you know what you're doing)
VIDEOMIND_DATA_DIR=/app/data
VIDEOMIND_DATABASE_URL=sqlite:////app/data/videomind.db

# ── Device (CPU default for Docker) ──────────────────────────────────────
VIDEOMIND_DEVICE=cpu
# VIDEOMIND_YOLO_DEVICE=
# VIDEOMIND_WHISPER_DEVICE=
# VIDEOMIND_WHISPER_COMPUTE_TYPE=int8
# VIDEOMIND_SAM2_DEVICE=

# ── Planner ──────────────────────────────────────────────────────────────
VIDEOMIND_PLANNER_PROVIDER=rule
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash

# ── Upload Limits ────────────────────────────────────────────────────────
VIDEOMIND_MAX_UPLOAD_MB=1024
VIDEOMIND_MAX_VIDEO_DURATION_SEC=7200

# ── Task Queue ───────────────────────────────────────────────────────────
VIDEOMIND_MAX_QUEUE_SIZE=20
VIDEOMIND_WORKER_CONCURRENCY=1
VIDEOMIND_TASK_TIMEOUT_SEC=3600
VIDEOMIND_STEP_TIMEOUT_SEC=900
VIDEOMIND_TASK_STALE_SEC=1800

# ── Storage ──────────────────────────────────────────────────────────────
VIDEOMIND_MIN_FREE_DISK_GB=5
VIDEOMIND_MAX_TASK_STORAGE_MB=2048
VIDEOMIND_MONITOR_INTERVAL_SEC=30

# ── Highlight Scoring ────────────────────────────────────────────────────
# VIDEOMIND_HIGHLIGHT_W_OBJECT=0.25
# VIDEOMIND_HIGHLIGHT_W_MOTION=0.20
# VIDEOMIND_HIGHLIGHT_W_SPEECH=0.20
# VIDEOMIND_HIGHLIGHT_W_SCENE=0.15
# VIDEOMIND_HIGHLIGHT_W_QUALITY=0.20
# VIDEOMIND_HIGHLIGHT_DIVERSITY_LAMBDA=0.15
